<Window x:Class="taskChatt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CYBIEEE — Cybersecurity Awareness Bot"
        Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#FF4EB4AC">

        <!-- Left: Bot image placeholder -->
        <Border Background="#FF3A8E87" HorizontalAlignment="Left"
                Width="340" Margin="10,10,0,10" CornerRadius="10">
            <TextBlock Text="🤖" FontSize="120" HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Right: Login panel -->
        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                    Width="400" Margin="0,0,30,0">

            <TextBlock Text="CYBIEEE" FontSize="36" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>

            <TextBlock Text="Cybersecurity Awareness Bot"
                       FontSize="16" Foreground="#DDFFFFFF"
                       HorizontalAlignment="Center" Margin="0,4,0,30"/>

            <TextBlock Text="Enter your name:" Foreground="White"
                       FontSize="14" Margin="0,0,0,6"/>

            <Border CornerRadius="6" Background="White"
                    BorderBrush="#0B39B1" BorderThickness="2">
                <TextBox x:Name="txtName" Background="Transparent"
                         BorderThickness="0" Padding="10,6"
                         FontSize="16" VerticalContentAlignment="Center"/>
            </Border>

            <Button x:Name="btnStart" Content="Start Chat"
                    Margin="0,16,0,0" Height="44"
                    Background="#FF201F1F" Foreground="White"
                    FontWeight="Bold" FontSize="18"
                    BorderBrush="#FF1421A6"
                    Click="btnStart_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="2" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

    </Grid>
</Window>
