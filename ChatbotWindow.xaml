<Window x:Class="taskChatt.ChatbotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CYBIEEE — Cybersecurity Awareness Chatbot"
        Height="620" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#FF2D2D2D">

    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,6"/>
        </Style>
        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Background" Value="#FF6C03CE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="DangerBtn">
            <Setter Property="Background" Value="#FFCC3300"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="GreenBtn">
            <Setter Property="Background" Value="#FF2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Background="#FF1A1A2E">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="🤖 CYBIEEE" FontSize="22" FontWeight="Bold"
                           Foreground="#FF6C03CE" VerticalAlignment="Center"/>
                <TextBlock x:Name="lblUser" FontSize="14" Foreground="#AAFFFFFF"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tab control -->
        <TabControl Grid.Row="1" x:Name="MainTabs"
                    Background="#FF2D2D2D" BorderThickness="0">

            <!-- ═══════════════════════════════════════════
                 TAB 1: CHAT
                 ═══════════════════════════════════════════ -->
            <TabItem Header="💬 Chat" Background="#FF3A3A5C" Foreground="White">
                <Grid Background="#FF2D2D2D">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="10,10,10,0">
                        <StackPanel x:Name="pnlChat" Margin="6"/>
                    </ScrollViewer>

                    <!-- Input row -->
                    <Grid Grid.Row="1" Margin="10,8,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="10"
                                Background="White" BorderBrush="#666" BorderThickness="1">
                            <TextBox x:Name="txtMessage"
                                     Background="Transparent" BorderThickness="0"
                                     Padding="12,8" FontSize="14"
                                     VerticalContentAlignment="Center"
                                     KeyDown="txtMessage_KeyDown"/>
                        </Border>
                        <Button Grid.Column="1" Content="Send" Margin="8,0,0,0"
                                Height="40" Width="80"
                                Style="{StaticResource ActionBtn}"
                                Click="btnSend_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════
                 TAB 2: TASKS
                 ═══════════════════════════════════════════ -->
            <TabItem Header="📋 Tasks" Background="#FF3A3A5C" Foreground="White">
                <Grid Background="#FF2D2D2D" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Add task form -->
                    <Border Grid.Row="0" Background="#FF3A3A5C"
                            CornerRadius="10" Padding="14" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Add New Cybersecurity Task"
                                       Foreground="White" FontSize="15"
                                       FontWeight="Bold" Margin="0,0,0,10"/>

                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Title:" Foreground="#AAFFFFFF"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1" CornerRadius="6" Background="White">
                                    <TextBox x:Name="txtTaskTitle" BorderThickness="0"
                                             Padding="8,5" FontSize="13"
                                             Background="Transparent"/>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="2" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Details:" Foreground="#AAFFFFFF"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1" CornerRadius="6" Background="White">
                                    <TextBox x:Name="txtTaskDesc" BorderThickness="0"
                                             Padding="8,5" FontSize="13"
                                             Background="Transparent"/>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Reminder:" Foreground="#AAFFFFFF"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1" CornerRadius="6" Background="White"
                                        Margin="0,0,8,0">
                                    <DatePicker x:Name="dpReminder"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                FontSize="13" Padding="4,3"/>
                                </Border>
                                <Button Grid.Column="2" Content="➕ Add Task"
                                        Style="{StaticResource ActionBtn}"
                                        Click="btnAddTask_Click"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Task list -->
                    <ListBox x:Name="lstTasks" Grid.Row="1"
                             Background="#FF1E1E2E" BorderThickness="0"
                             Foreground="White" FontSize="14"
                             SelectionMode="Single"/>

                    <!-- Action buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                Margin="0,10,0,0" HorizontalAlignment="Center">
                        <Button Content="✅ Mark Complete" Margin="6,0"
                                Style="{StaticResource GreenBtn}"
                                Click="btnMarkComplete_Click"/>
                        <Button Content="🗑️ Delete Task" Margin="6,0"
                                Style="{StaticResource DangerBtn}"
                                Click="btnDeleteTask_Click"/>
                        <Button Content="🔄 Refresh" Margin="6,0"
                                Style="{StaticResource ActionBtn}"
                                Click="btnRefreshTasks_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════
                 TAB 3: QUIZ
                 ═══════════════════════════════════════════ -->
            <TabItem Header="🎮 Quiz" Background="#FF3A3A5C" Foreground="White">
                <Grid Background="#FF2D2D2D" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Score / progress -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border Background="#FF3A3A5C" CornerRadius="8" Padding="12,6" Margin="6,0">
                            <TextBlock x:Name="lblQuizProgress" Text="Question: 0 / 0"
                                       Foreground="White" FontSize="14"/>
                        </Border>
                        <Border Background="#FF3A3A5C" CornerRadius="8" Padding="12,6" Margin="6,0">
                            <TextBlock x:Name="lblQuizScore" Text="Score: 0"
                                       Foreground="#FF90EE90" FontSize="14" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <!-- Question -->
                    <Border Grid.Row="1" Background="#FF3A3A5C"
                            CornerRadius="10" Padding="18" Margin="0,0,0,14">
                        <TextBlock x:Name="lblQuestion"
                                   Text="Press 'Start Quiz' to begin!"
                                   Foreground="White" FontSize="16"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </Border>

                    <!-- Answer options -->
                    <StackPanel x:Name="pnlAnswers" Grid.Row="2" Margin="0,0,0,14"/>

                    <!-- Feedback -->
                    <Border x:Name="borderFeedback" Grid.Row="3"
                            Background="#FF1E1E2E" CornerRadius="8"
                            Padding="14" Margin="0,0,0,14"
                            Visibility="Collapsed">
                        <TextBlock x:Name="lblFeedback" Foreground="#FFFFCC00"
                                   FontSize="14" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Quiz controls -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button x:Name="btnStartQuiz" Content="▶ Start Quiz"
                                Margin="8,0" Style="{StaticResource ActionBtn}"
                                Click="btnStartQuiz_Click"/>
                        <Button x:Name="btnNextQuestion" Content="Next ▶"
                                Margin="8,0" Style="{StaticResource GreenBtn}"
                                Visibility="Collapsed"
                                Click="btnNextQuestion_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════
                 TAB 4: ACTIVITY LOG
                 ═══════════════════════════════════════════ -->
            <TabItem Header="📜 Activity Log" Background="#FF3A3A5C" Foreground="White">
                <Grid Background="#FF2D2D2D" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Recent Activity (last 10 actions)"
                               Foreground="#AAFFFFFF" FontSize="15"
                               Margin="4,0,0,10"/>

                    <ListBox x:Name="lstActivityLog" Grid.Row="1"
                             Background="#FF1E1E2E" BorderThickness="0"
                             Foreground="#FFCCFFCC" FontSize="13"
                             FontFamily="Consolas"/>

                    <Button Grid.Row="2" Content="🗑️ Clear Log"
                            HorizontalAlignment="Right" Margin="0,10,0,0"
                            Style="{StaticResource DangerBtn}"
                            Click="btnClearLog_Click"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
